    [0x02] = "RMB",
    [0x08] = "Back",
    [0x09] = "Tab",
    [0x0D] = "Enter",
    [0x10] = "Shift",
    [0x11] = "Ctrl",
    [0x12] = "Alt",
    [0x14] = "Caps",
