-- VenusGUI
-- Drawing-based GUI for Matcha LuaVM scripts.
-- Same architecture as MatchaGUI (config save/load, keybinds, slider editing,
-- dragging, hotkeys), restyled to match the Venus Library look.

local VenusGUI = {}

local Drawing_new = Drawing.new
local Vector2_new = Vector2.new
local Color3_fromRGB = Color3.fromRGB
local math_floor = math.floor
local math_max = math.max
local math_min = math.min
local string_format = string.format
local os_clock = os.clock

local FONT = Drawing.Fonts.Monospace
pcall(function() FONT = Drawing.Fonts.System end)
local FONT_BOLD = FONT
pcall(function() FONT_BOLD = Drawing.Fonts.SystemBold end)

