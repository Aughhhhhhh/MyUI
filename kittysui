    aimMainSec:Toggle("aim_enabled", "enabled", false, nil)
    aimMainSec:Combo("aim_origin", "origin", { "camera", "head", "chest" }, 0)
    aimMainSec:Combo("aim_hitbox", "hitbox", { "head", "chest", "closest" }, 0)
    aimMainSec:Toggle("aim_autofire", "automatic fire", false, nil)

    local aaMain = aimAntiAim:Section("anti aim")
    aaMain:Toggle("aa_enabled", "enabled", false)
    aaMain:SliderInt("aa_yaw", "yaw offset", -180, 180, 0)
    aaMain:Combo("aa_mode", "mode", { "static", "jitter", "spin" }, 0)

    -- Trigger
    local triggerMain = trigger:Page("triggerbot"):Section("main")
    triggerMain:Toggle("trigger_enabled", "enabled", false, nil, { Keybind = 0x46, KeybindMode = "hold" })
    triggerMain:SliderInt("trigger_delay", "delay", 0, 1000, 125)
    triggerMain:SliderFloat("trigger_chance", "hit chance", 0, 100, 75, "%.1f")

    -- Visuals
    local espPage = visuals:Page("esp"):Section("main")
    espPage:Toggle("esp_enabled", "enabled", true)
    espPage:Toggle("esp_boxes", "boxes", true)
    espPage:Toggle("esp_names", "names", true)
    espPage:SliderInt("esp_distance", "max distance", 100, 10000, 2500)
    espPage:ColorPicker("esp_color", "esp color", 95, 110, 255)

    -- Misc
    local moveSec = misc:Page("movement"):Section("main")
    moveSec:Toggle("bhop", "bunny hop", false)
    moveSec:SliderInt("walk", "walk speed", 16, 250, 16)
    moveSec:Keybind("move_key", "movement key", 0x47, "toggle")

    -- Configs tab: full save/load workflow, same as MatchaGUI
    local configsPage = configs:Page("configs")
    local configStatus
    local configDropdown

    local function setStatus(text)
        text = asText(text)
        if configStatus then configStatus.label = text end
        print(text)
    end

    local function selectedConfigName()
        if configDropdown then
            local selected = asText(configDropdown:GetText())
            if selected ~= "" then return selected end
        end
        local name = asText(gui:GetValue("config_name"))
        if name == "" then name = "default" end
        return name
    end

    local function selectConfig(name)
        if not configDropdown then return end
        for i, item in ipairs(configDropdown:GetItems()) do
            if item == name then configDropdown:SetValue(i - 1); return end
        end
    end

    local function refreshStatus()
        local list = gui:ListConfigs()
        if configDropdown then configDropdown:SetItems(list) end
        if #list == 0 then setStatus("no configs saved")
        else setStatus("selected: " .. selectedConfigName()) end
    end

    local createSec = configsPage:Section("create")
    createSec:InputText("config_name", "name", "", nil, { skipConfig = true })
    createSec:Button("create", function()
        local name = asText(gui:GetValue("config_name"))
        if name == "" then name = "default" end
        local ok, msg = gui:SaveConfig(name)
        if ok then setStatus("saved: " .. msg); refreshStatus(); selectConfig(name)
        else setStatus("save failed: " .. tostring(msg)) end
    end)

    local manageSec = configsPage:Section("manage")
    configDropdown = manageSec:Combo("selected_config", "saved configs", {}, 0, function(_, text)
        text = asText(text)
        if text ~= "" then
            gui:SetValue("config_name", text)
            setStatus("selected: " .. text)
        end
    end, { skipConfig = true })
    configStatus = manageSec:Text("no configs saved")
    manageSec:Button("load", function()
        local name = selectedConfigName()
        local ok, msg = gui:LoadConfig(name)
        setStatus(ok and ("loaded: " .. name) or ("load failed: " .. tostring(msg)))
    end)
    manageSec:Button("update", function()
        local name = selectedConfigName()
        local ok, msg = gui:SaveConfig(name)
        if ok then setStatus("updated: " .. msg); refreshStatus(); selectConfig(name)
        else setStatus("update failed: " .. tostring(msg)) end
    end)
    manageSec:Button("delete", function()
        local name = selectedConfigName()
        local ok, msg = gui:DeleteConfig(name)
        if ok then setStatus("deleted: " .. msg); refreshStatus()
        else setStatus("delete failed: " .. tostring(msg)) end
    end)
    manageSec:Button("refresh", refreshStatus)

    local settingsSec = configsPage:Section("settings")
    settingsSec:MenuKeybind("menu_key", "menu key", 0x70)

    gui:SetTab(opts.Tab or "Aimbot")
    refreshStatus()

    if opts.Start ~= false then gui:Start() end
    if opts.Start ~= false and opts.Block ~= false then
        while not gui._destroyed do task.wait(60) end
    end

    return gui
end

function VenusGUI:ShowDemoMenu(opts) return self:Demo(opts) end

