-- Window value / config API --------------------------------------------------

function Window:GetValue(id)
    local widget = self._widgetsById[id]
    if widget then return widget.value end
    return self._values[id]
end

function Window:SetValue(id, value)
    local widget = self._widgetsById[id]
    if not widget then
        self._values[id] = value
        return false
    end
    if widget.kind == "menu_keybind" then
        self:SetMenuKey(value)
        if widget.callback then widget.callback(value, widget) end
        return true
    end
    if widget.kind == "combo" then
        widget:SetValue(value)
        return true
    end
    if widget.kind == "input_text" then value = asText(value) end
    widget.value = value
    self._values[id] = value
    if widget.callback then widget.callback(value, widget) end
    return true
end

function Window:GetConfigData()
    local data = { version = 1, values = {} }
    for id, widget in pairs(self._widgetsById) do
        local packed = encodeValue(widget)
        if packed ~= nil then data.values[id] = packed end
    end
    return data
end

function Window:ApplyConfigData(data)
    if not data or not data.values then return false, "invalid config" end
    for id, packed in pairs(data.values) do
        local widget = self._widgetsById[id]
        if widget and not widget.skipConfig then
            local value, ok = decodeValue(widget, packed)
            if ok then
                if widget.kind == "menu_keybind" then
                    self:SetMenuKey(value)
                    if widget.callback then widget.callback(value, widget) end
                elseif widget.kind == "combo" then
                    widget:SetValue(value)
                else
                    widget.value = value
                    self._values[id] = value
                    if widget.kind == "keybind" and packed.key then
                        widget.key = packed.key
                    end
                    if widget.callback then widget.callback(value, widget) end
                end
            end
        end
    end
    return true
end

function Window:ConfigPath(name)
    return joinPath(self.configFolder, cleanName(name) .. ".json")
end

function Window:SaveConfig(name)
    name = cleanName(name)
    local okFolder, folderErr = ensureFolderPath(self.configFolder)
    if not okFolder then return false, folderErr end
    if not writefile then return false, "writefile unavailable" end
    local http = getHttpService()
    if not http then return false, "HttpService unavailable" end
    local okEncode, encoded = pcall(function()
        return http:JSONEncode(self:GetConfigData())
    end)
    if not okEncode or not encoded then return false, "encode failed" end
    local okWrite = pcall(writefile, self:ConfigPath(name), encoded)
    if not okWrite then return false, "write failed" end
    return true, name
end

function Window:LoadConfig(name)
    name = cleanName(name)
    if not readfile or not isfile then return false, "readfile unavailable" end
    local path = self:ConfigPath(name)
    local okExists, exists = pcall(isfile, path)
    if not okExists or exists ~= true then return false, "config not found" end
    local okRead, raw = pcall(readfile, path)
    if not okRead or not raw then return false, "read failed" end
    local http = getHttpService()
    if not http then return false, "HttpService unavailable" end
    local okDecode, data = pcall(function() return http:JSONDecode(raw) end)
    if not okDecode or not data then return false, "decode failed" end
    return self:ApplyConfigData(data)
end

function Window:DeleteConfig(name)
    name = cleanName(name)
    if not delfile or not isfile then return false, "delfile unavailable" end
    local path = self:ConfigPath(name)
    local okExists, exists = pcall(isfile, path)
    if okExists and exists == true then
        local okDelete = pcall(delfile, path)
        if okDelete then return true, name end
        return false, "delete failed"
    end
    return false, "config not found"
end

function Window:ListConfigs()
    local out = {}
    ensureFolderPath(self.configFolder)
    if not listfiles then return out end
    local okList, files = pcall(listfiles, self.configFolder)
    if okList and files then
        for _, path in ipairs(files) do
            local name = fileName(path)
            if name:match("%.json$") or name:match("%.cfg$") then
                table.insert(out, stripExt(name))
            end
        end
    end
    table.sort(out)
    return out
end

function Window:IsKeyActive(id)
    local widget = self._widgetsById[id]
    if not widget then return false end
    if widget.kind == "keybind" then return widget.value == true end
    if widget.kind == "toggle_keybind" then
        return widget.value == true and widget.bindActive == true
    end
    return false
end

function Window:SetMenuKey(vk)
    vk = asNumber(vk, nil)
    if not vk then return false end
    self.toggleKey = vk
    self._lastToggleKey = readKey(vk)
    for _, tab in ipairs(self._tabs) do
        for _, section in ipairs(tab.sections) do
            for _, widget in ipairs(section.widgets) do
                if widget.kind == "menu_keybind" then
                    widget.key = vk
                    widget.value = vk
                    self._values[widget.id] = vk
                end
            end
        end
    end
    return true
end

function Window:SetVisible(visible)
    self.visible = visible == true
    self:_applyVisibility()
end

function Window:Toggle()
    self.visible = not self.visible
    self:_applyVisibility()
end

function Window:Start()
    if self._destroyed then return self end
    if self._running then return self end
    self._running = true
    if self._connection then return self end
    local ok, rs = pcall(function() return game:GetService("RunService") end)
    if ok and rs and rs.RenderStepped then
        self._connection = rs.RenderStepped:Connect(function(dt)
            if self._running then self:Step(dt) end
        end)
    else
        task.spawn(function()
            while self._running do
                self:Step(0)
                task.wait()
            end
        end)
    end
    return self
end

function Window:Stop() self._running = false end

function Window:Disconnect()
    self._running = false
    if self._connection then
        local conn = self._connection
        self._connection = nil
        task.defer(function() pcall(function() conn:Disconnect() end) end)
    end
end

function Window:Destroy()
    self._running = false
    self._destroyed = true
    if self._connection then
        local conn = self._connection
        self._connection = nil
        task.defer(function() pcall(function() conn:Disconnect() end) end)
    end
    removeAll(self._drawings)
end

-- Mouse / hotkeys ------------------------------------------------------------

function Window:_readMouse()
    local mx, my = self._mouse.x, self._mouse.y
    local ok, player = pcall(function()
        local players = game:GetService("Players")
        return players and players.LocalPlayer
    end)
    if ok and player then
        local okMouse, mouse = pcall(function() return player:GetMouse() end)
        if okMouse and mouse then
            mx = mouse.X or mx
            my = mouse.Y or my
        end
    end
    local active = robloxActive()
    local down = false
    local rightDown = false
    if active then
        down = readMouseDown()
        rightDown = readMouse2Down()
    end
    local wasDown = self._mouse.down
    local wasRightDown = self._mouse.rightDown
    self._mouse.px = self._mouse.x
    self._mouse.py = self._mouse.y
    self._mouse.x = mx
    self._mouse.y = my
    self._mouse.down = down
    self._mouse.clicked = down and not wasDown
    self._mouse.released = (not down) and wasDown
    self._mouse.rightDown = rightDown
    self._mouse.rightClicked = rightDown and not wasRightDown
    self._mouse.rightReleased = (not rightDown) and wasRightDown
end

function Window:_beginSliderEdit(widget)
    if not widget or widget.kind ~= "slider" then return end
    local minValue = sliderLimits(widget)
    local value = normalizeSliderValue(widget, widget.value or minValue) or minValue
    if self._activeCombo then
        self._activeCombo.open = false
        self._activeCombo = nil
    end
    if self._listeningBind then
        self._listeningBind.listening = false
        self._listeningBind = nil
    end
    self._activeSlider = nil
    self._activeText = widget
    self._textLastKeys = {}
    widget.editText = formatSliderValue(widget, value)
    widget.editInvalid = false
end

function Window:_clearSliderEdit(widget)
    if widget and widget.kind == "slider" then
        widget.editText = nil
        widget.editInvalid = false
    end
    if self._activeText == widget then self._activeText = nil end
    self._textLastKeys = {}
end

function Window:_handleHotkeys()
    local active = robloxActive()
    local down = false
    if active then down = readKey(self.toggleKey) end
    if down and not self._lastToggleKey and not self._listeningBind and not self._activeText then
        self:Toggle()
    end
    self._lastToggleKey = down

    if not active then return end

    if self._activeText then
        local widget = self._activeText
        if widget.kind == "slider" then
            local changed = false
            local value = asText(widget.editText)
            for _, vk in ipairs(KEY_SCAN) do
                local keyDown = readKey(vk)
                local wasDown = self._textLastKeys[vk] == true
                if keyDown and not wasDown then
                    if vk == 0x0D then
                        local ok = applySliderValue(self, widget, tonumber(value))
                        if ok then
                            self:_clearSliderEdit(widget)
                            break
                        end
                        widget.editInvalid = true
                    elseif vk == 0x1B then
                        self:_clearSliderEdit(widget); break
                    elseif vk == 0x08 then
                        if #value > 0 then
                            value = string.sub(value, 1, #value - 1)
                            changed = true
                        end
                    elseif vk == 0x2E then
                        value = ""; changed = true
                    else
                        local ch = numericCharFromKey(vk)
                        if ch and #value < 18 then
                            if ch == "." then
                                if not string.find(value, ".", 1, true) then
                                    value = value .. ch; changed = true
                                end
                            elseif ch == "-" or ch == "+" then
                                if #value == 0 then
                                    value = value .. ch; changed = true
                                end
                            else
                                value = value .. ch; changed = true
                            end
                        end
                    end
                end
                self._textLastKeys[vk] = keyDown
            end
            if changed then
                widget.editText = value
                widget.editInvalid = false
            end
            releaseTextBlockKeys()
            return
        end

        local changed = false
        local value = asText(widget.value)
        for _, vk in ipairs(KEY_SCAN) do
            local keyDown = readKey(vk)
            local wasDown = self._textLastKeys[vk] == true
            if keyDown and not wasDown then
                if vk == 0x0D or vk == 0x1B then
                    self._activeText = nil
                    self._textLastKeys = {}
                    break
                elseif vk == 0x08 then
                    if #value > 0 then
                        value = string.sub(value, 1, #value - 1)
                        changed = true
                    end
                else
                    local ch = charFromKey(vk)
                    if ch and #value < 64 then
                        value = value .. ch; changed = true
                    end
                end
            end
            self._textLastKeys[vk] = keyDown
        end
        if changed then
            widget.value = value
            self._values[widget.id] = value
            if widget.callback then widget.callback(value, widget) end
        end
        releaseTextBlockKeys()
        return
    end

    if self._listeningBind then
        local target = self._listeningBind
        for _, vk in ipairs(KEY_SCAN) do
            if readKey(vk) then
                if target.kind == "menu_keybind" then
                    self:SetMenuKey(vk)
                    if target.callback then target.callback(vk, target) end
                else
                    target.key = vk
                end
                target.listening = false
                self._listeningBind = nil
                break
            end
        end
    end

    for _, tab in ipairs(self._tabs) do
        for _, section in ipairs(tab.sections) do
            for _, widget in ipairs(section.widgets) do
                if widget.kind == "keybind" and widget.key then
                    local keyDown = readKey(widget.key)
                    local old = widget.value
                    if widget.mode == "hold" then
                        widget.value = keyDown
                    elseif keyDown and not widget.lastKeyDown then
                        widget.value = not widget.value
                    end
                    if old ~= widget.value then
                        self._values[widget.id] = widget.value
                        if widget.callback then
                            widget.callback(widget.value, widget.key, widget)
                        end
                    end
                    widget.lastKeyDown = keyDown
                elseif widget.kind == "toggle_keybind" and widget.key then
                    local keyDown = readKey(widget.key)
                    local oldActive = widget.bindActive
                    if widget.mode == "hold" then
                        widget.bindActive = keyDown
                    elseif keyDown and not widget.lastKeyDown then
                        widget.bindActive = not widget.bindActive
                    end
                    if oldActive ~= widget.bindActive and widget.callback then
                        widget.callback(widget.value, widget.key, widget.bindActive, widget)
                    end
                    widget.lastKeyDown = keyDown
                end
            end
        end
    end
end

function Window:_applyVisibility()
    if self.visible then return end
    for _, obj in ipairs(self._drawings) do
        setVisible(obj, false)
    end
end

-- Layout ---------------------------------------------------------------------

function Window:_layoutShell()
    local x, y, w, h = self.x, self.y, self.w, self.h
    local theme = self.theme
    local visible = self.visible

    local r = 8
    layoutRoundedFill(self.cardBorder, x - 1, y - 1, w + 2, h + 2, r + 1, theme.stroke2)
    layoutRoundedFill(self.card, x, y, w, h, r, theme.card)
    setRoundedFillVisible(self.cardBorder, visible)
    setRoundedFillVisible(self.card, visible)

    self.titleText.Text = self.title
    self.titleText.Size = 14
    self.titleText.Color = theme.text
    self.titleText.Position = Vector2_new(x + 18, y + 14)
    setVisible(self.titleText, visible)
end

function Window:_layoutTabs()
    local count = #self._tabs
    if count <= 0 then return end

    local theme = self.theme
    local pad = 16
    local tabH = 22
    local gap = 6
    local x = self.x + pad
    local y = self.y + 42
    local mx, my = self._mouse.x, self._mouse.y

    for i, tab in ipairs(self._tabs) do
        local label = tab.name
        local tabW = math_max(60, #label * 8 + 16)
        local tx = x

        local hover = inside(mx, my, tx, y, tabW, tabH)
        if self.visible and self._mouse.clicked and hover then
            self._activeTab = tab
        end

        local active = self._activeTab == tab
        local pillColor = active and theme.panel or theme.card
        layoutRoundedFill(tab.pill, tx, y, tabW, tabH, 4, pillColor)
        setRoundedFillVisible(tab.pill, self.visible)

        tab.label.Text = label
        tab.label.Color = active and theme.text or theme.muted
        tab.label.Size = 12
        tab.label.Center = true
        tab.label.Position = Vector2_new(tx + math_floor(tabW / 2), y + math_floor(tabH / 2) - 6)
        setVisible(tab.label, self.visible)

        x = x + tabW + gap
    end
end

function Window:_layoutSections()
    local tab = self._activeTab
    local theme = self.theme
    local pad = 16
    local bodyX = self.x + pad
    local bodyY = self.y + 78
    local bodyW = self.w - pad * 2
    local cursorY = bodyY

    for _, otherTab in ipairs(self._tabs) do
        for _, section in ipairs(otherTab.sections) do
            local activeSection = otherTab == tab and self.visible

            local titleH = 18
            local contentH = 10
            for _, widget in ipairs(section.widgets) do
                contentH = contentH + widget.h + 2
            end
            local sectionH = titleH + contentH + 6

            if activeSection then
                local sx = bodyX
                local sy = cursorY
                local sw = bodyW
                local sh = sectionH

                layoutRoundedFill(section.fillBorder, sx - 1, sy - 1, sw + 2, sh + 2, 7, theme.stroke)
                layoutRoundedFill(section.fill, sx, sy, sw, sh, 6, theme.bg)
                setRoundedFillVisible(section.fillBorder, true)
                setRoundedFillVisible(section.fill, true)

                section.header.Text = section.name
                section.header.Color = theme.text
                section.header.Size = 12
                section.header.Position = Vector2_new(sx + 12, sy + 6)
                setVisible(section.header, true)

                local wy = sy + titleH + 6
                for _, widget in ipairs(section.widgets) do
                    widget.x = sx + 10
                    widget.y = wy
                    widget.w = sw - 20
                    self:_layoutWidget(widget, true)
                    wy = wy + widget.h + 2
                end

                cursorY = cursorY + sectionH + 8
            else
                setRoundedFillVisible(section.fillBorder, false)
                setRoundedFillVisible(section.fill, false)
                setVisible(section.header, false)
                for _, widget in ipairs(section.widgets) do
                    self:_layoutWidget(widget, false)
                end
            end
        end
    end
end

-- Per-widget visibility helper ----------------------------------------------

local function hideWidget(widget)
    if widget.fill then setRoundedFillVisible(widget.fill, false) end
    if widget.fillBorder then setRoundedFillVisible(widget.fillBorder, false) end
    if widget.fillBg then setRoundedFillVisible(widget.fillBg, false) end
    if widget.fillBar then setRoundedFillVisible(widget.fillBar, false) end
    if widget.editBox then setRoundedFillVisible(widget.editBox, false) end
    if widget.editBorder then setRoundedBorderVisible(widget.editBorder, false) end
    if widget.dropdown then setRoundedFillVisible(widget.dropdown, false) end
    if widget.dropdownBorder then setRoundedFillVisible(widget.dropdownBorder, false) end
    setVisible(widget.dotOuter, false)
    setVisible(widget.dotInner, false)
    setVisible(widget.swatch, false)
    setVisible(widget.dot, false)
    setVisible(widget.labelText, false)
    setVisible(widget.valueText, false)
    setVisible(widget.arrow, false)
    if widget.optionTexts then
        for _, t in ipairs(widget.optionTexts) do setVisible(t, false) end
    end
    if widget.optionHovers then
        for _, b in ipairs(widget.optionHovers) do setVisible(b, false) end
    end
end

function Window:_layoutWidget(widget, visible)
    if not visible then hideWidget(widget); return end

    local mx, my = self._mouse.x, self._mouse.y
    local hover = inside(mx, my, widget.x, widget.y, widget.w, widget.h)
    local clicked = self._mouse.clicked and hover
    local theme = self.theme

    if widget.kind == "toggle" then
        if clicked then
            widget.value = not widget.value
            self._values[widget.id] = widget.value
            if widget.callback then widget.callback(widget.value, widget) end
        end
        local cx = widget.x + 7
        local cy = widget.y + math_floor(widget.h / 2)
        widget.dotOuter.Position = Vector2_new(cx, cy)
        widget.dotOuter.Radius = 5
        widget.dotOuter.Color = widget.value and theme.accent or theme.muted
        widget.dotInner.Position = Vector2_new(cx, cy)
        widget.dotInner.Radius = 3
        widget.dotInner.Color = theme.accent
        setVisible(widget.dotOuter, true)
        setVisible(widget.dotInner, widget.value == true)
        widget.labelText.Text = widget.label
        widget.labelText.Size = 13
        widget.labelText.Color = widget.value and theme.text or theme.muted
        widget.labelText.Position = Vector2_new(widget.x + 18, widget.y + 2)
        setVisible(widget.labelText, true)

    elseif widget.kind == "slider" then
        local minValue, maxValue = sliderLimits(widget)
        local rowHit = hover
        local editingSlider = self._activeText == widget

        if self._mouse.rightClicked and rowHit then
            self:_beginSliderEdit(widget); editingSlider = true
        elseif self._mouse.clicked and editingSlider and not rowHit then
            self:_clearSliderEdit(widget); editingSlider = false
        end

        if self._mouse.clicked and not editingSlider and rowHit then
            self._activeSlider = widget
        end
        if self._mouse.released and self._activeSlider == widget then
            self._activeSlider = nil
        end
        if self._activeSlider == widget and self._mouse.down then
            local pct = clamp((mx - widget.x) / widget.w, 0, 1)
            local raw = minValue + (maxValue - minValue) * pct
            applySliderValue(self, widget, raw)
        end

        local value = normalizeSliderValue(widget, widget.value or minValue) or minValue
        local pct = (value - minValue) / (maxValue - minValue)

        layoutRoundedFill(widget.fillBorder, widget.x - 1, widget.y - 1, widget.w + 2, widget.h + 2, 4, theme.stroke)
        layoutRoundedFill(widget.fillBg, widget.x, widget.y, widget.w, widget.h, 3, theme.panel)
        setRoundedFillVisible(widget.fillBorder, true)
        setRoundedFillVisible(widget.fillBg, true)

        local barW = math_max(8, math_floor(widget.w * pct))
        layoutRoundedFill(widget.fillBar, widget.x, widget.y, barW, widget.h, 3, theme.accent2)
        setRoundedFillVisible(widget.fillBar, pct > 0)

        if editingSlider then
            local editW = 80
            local editX = widget.x + widget.w - editW - 2
            local editY = widget.y + 1
            local editH = widget.h - 2
            layoutRoundedFill(widget.editBox, editX, editY, editW, editH, 3, theme.control2)
            layoutRoundedBorder(widget.editBorder, editX, editY, editW, editH, 3,
                widget.editInvalid and theme.danger or theme.accent)
            setRoundedFillVisible(widget.editBox, true)
            setRoundedBorderVisible(widget.editBorder, true)
            widget.labelText.Text = asText(widget.editText) .. "|"
            widget.labelText.Color = widget.editInvalid and theme.danger or theme.text
            widget.labelText.Center = true
            widget.labelText.Position = Vector2_new(editX + math_floor(editW / 2), widget.y + 5)
        else
            widget.labelText.Text = widget.label .. ": " .. formatSliderValue(widget, value)
            widget.labelText.Color = theme.text
            widget.labelText.Center = true
            widget.labelText.Position = Vector2_new(widget.x + math_floor(widget.w / 2), widget.y + 5)
        end
        widget.labelText.Size = 12
        setVisible(widget.labelText, true)

    elseif widget.kind == "button" then
        if clicked and widget.callback then widget.callback(widget) end
        local fillColor = hover and theme.panel2 or theme.panel
        layoutRoundedFill(widget.fillBorder, widget.x - 1, widget.y - 1, widget.w + 2, widget.h + 2, 4, theme.stroke)
        layoutRoundedFill(widget.fill, widget.x, widget.y, widget.w, widget.h, 3, fillColor)
        setRoundedFillVisible(widget.fillBorder, true)
        setRoundedFillVisible(widget.fill, true)
        widget.labelText.Text = widget.label
        widget.labelText.Size = 12
        widget.labelText.Color = theme.text
        widget.labelText.Center = true
        widget.labelText.Position = Vector2_new(widget.x + math_floor(widget.w / 2), widget.y + 5)
        setVisible(widget.labelText, true)

    elseif widget.kind == "keybind" or widget.kind == "menu_keybind" then
        if clicked then
            if self._listeningBind then self._listeningBind.listening = false end
            self._listeningBind = widget
            widget.listening = true
        end
        widget.labelText.Text = widget.label
        widget.labelText.Size = 13
        widget.labelText.Color = theme.text
        widget.labelText.Position = Vector2_new(widget.x + 2, widget.y + 2)
        setVisible(widget.labelText, true)
        widget.valueText.Text = widget.listening and "..." or keyName(widget.key)
        widget.valueText.Size = 12
        widget.valueText.Center = false
        local rightX = widget.x + widget.w - (#asText(widget.valueText.Text) * 7)
        widget.valueText.Color = widget.listening and theme.accent2
            or (widget.kind == "keybind" and widget.value and theme.accent or theme.text)
        widget.valueText.Position = Vector2_new(rightX, widget.y + 3)
        setVisible(widget.valueText, true)

    elseif widget.kind == "toggle_keybind" then
        local toggleHit = inside(mx, my, widget.x, widget.y, widget.w * 0.6, widget.h)
        local keyHit = inside(mx, my, widget.x + widget.w * 0.6, widget.y, widget.w * 0.4, widget.h)
        if self._mouse.clicked and toggleHit then
            widget.value = not widget.value
            self._values[widget.id] = widget.value
            if widget.callback then
                widget.callback(widget.value, widget.key, widget.bindActive, widget)
            end
        end
        if self._mouse.clicked and keyHit then
            if self._listeningBind then self._listeningBind.listening = false end
            self._listeningBind = widget
            widget.listening = true
        end
        local cx = widget.x + 7
        local cy = widget.y + math_floor(widget.h / 2)
        widget.dotOuter.Position = Vector2_new(cx, cy); widget.dotOuter.Radius = 5
        widget.dotOuter.Color = widget.value and theme.accent or theme.muted
        widget.dotInner.Position = Vector2_new(cx, cy); widget.dotInner.Radius = 3
        widget.dotInner.Color = theme.accent
        setVisible(widget.dotOuter, true)
        setVisible(widget.dotInner, widget.value == true)
        widget.labelText.Text = widget.label
        widget.labelText.Size = 13
        widget.labelText.Color = widget.value and theme.text or theme.muted
        widget.labelText.Position = Vector2_new(widget.x + 18, widget.y + 2)
        setVisible(widget.labelText, true)
        widget.valueText.Text = widget.listening and "..." or keyName(widget.key)
        widget.valueText.Size = 12
        widget.valueText.Center = false
        local txt = asText(widget.valueText.Text)
        widget.valueText.Color = widget.listening and theme.accent2
            or (widget.bindActive and theme.accent or theme.text)
        widget.valueText.Position = Vector2_new(widget.x + widget.w - #txt * 7, widget.y + 3)
        setVisible(widget.valueText, true)

    elseif widget.kind == "input_text" then
        local activeText = self._activeText == widget
        if self._mouse.clicked then
            if hover then
                self._activeText = widget
                self._textLastKeys = {}
            elseif activeText then
                self._activeText = nil
                self._textLastKeys = {}
            end
        end
        local borderColor = activeText and theme.accent or theme.stroke
        layoutRoundedFill(widget.fillBorder, widget.x - 1, widget.y - 1, widget.w + 2, widget.h + 2, 4, borderColor)
        layoutRoundedFill(widget.fill, widget.x, widget.y, widget.w, widget.h, 3, theme.panel)
        setRoundedFillVisible(widget.fillBorder, true)
        setRoundedFillVisible(widget.fill, true)
        local display = asText(widget.value)
        if activeText then display = display .. "|" end
        if display == "" then
            display = widget.label
            widget.valueText.Color = theme.muted
        else
            widget.valueText.Color = theme.text
        end
        widget.valueText.Text = display
        widget.valueText.Size = 12
        widget.valueText.Center = true
        widget.valueText.Position = Vector2_new(widget.x + math_floor(widget.w / 2), widget.y + 5)
        setVisible(widget.valueText, true)

    elseif widget.kind == "combo" then
        local maxRows = math_min(#widget.items, #widget.optionTexts)
        local rowH = 18

        if self._mouse.clicked then
            if hover then
                if self._activeCombo and self._activeCombo ~= widget then
                    self._activeCombo.open = false
                end
                widget.open = not widget.open
                self._activeCombo = widget.open and widget or nil
            elseif widget.open then
                local picked = false
                for i = 1, maxRows do
                    local oy = widget.y + widget.h + 2 + (i - 1) * rowH
                    if inside(mx, my, widget.x, oy, widget.w, rowH) then
                        widget:SetValue(i - 1)
                        picked = true
                        break
                    end
                end
                widget.open = false
                self._activeCombo = nil
                if not picked and not inside(mx, my, widget.x, widget.y, widget.w, widget.h + 2 + maxRows * rowH) then
                    widget.open = false
                end
            end
        end

        local borderColor = widget.open and theme.accent or theme.stroke
        layoutRoundedFill(widget.fillBorder, widget.x - 1, widget.y - 1, widget.w + 2, widget.h + 2, 4, borderColor)
        layoutRoundedFill(widget.fill, widget.x, widget.y, widget.w, widget.h, 3, theme.panel)
        setRoundedFillVisible(widget.fillBorder, true)
        setRoundedFillVisible(widget.fill, true)

        widget.valueText.Text = widget:GetText()
        widget.valueText.Size = 12
        widget.valueText.Color = theme.text
        widget.valueText.Center = false
        widget.valueText.Position = Vector2_new(widget.x + 8, widget.y + 5)
        setVisible(widget.valueText, true)

        local arrowX = widget.x + widget.w - 12
        local arrowY = widget.y + math_floor(widget.h / 2)
        if widget.open then
            widget.arrow.PointA = Vector2_new(arrowX - 4, arrowY + 2)
            widget.arrow.PointB = Vector2_new(arrowX + 4, arrowY + 2)
            widget.arrow.PointC = Vector2_new(arrowX, arrowY - 3)
        else
            widget.arrow.PointA = Vector2_new(arrowX - 4, arrowY - 2)
            widget.arrow.PointB = Vector2_new(arrowX + 4, arrowY - 2)
            widget.arrow.PointC = Vector2_new(arrowX, arrowY + 3)
        end
        widget.arrow.Color = theme.muted
        setVisible(widget.arrow, true)

        if widget.open and maxRows > 0 then
            local dx = widget.x
            local dy = widget.y + widget.h + 2
            local dh = maxRows * rowH
            layoutRoundedFill(widget.dropdownBorder, dx - 1, dy - 1, widget.w + 2, dh + 2, 4, theme.stroke)
            layoutRoundedFill(widget.dropdown, dx, dy, widget.w, dh, 3, theme.panel)
            setRoundedFillVisible(widget.dropdownBorder, true)
            setRoundedFillVisible(widget.dropdown, true)
            for i = 1, #widget.optionTexts do
                local box = widget.optionHovers[i]
                local txt = widget.optionTexts[i]
                if i <= maxRows then
                    local oy = dy + (i - 1) * rowH
                    local rowHover = inside(mx, my, dx, oy, widget.w, rowH)
                    box.Position = Vector2_new(dx, oy)
                    box.Size = Vector2_new(widget.w, rowH)
                    box.Color = theme.hover
                    setVisible(box, rowHover)
                    txt.Text = asText(widget.items[i])
                    txt.Size = 12
                    txt.Center = false
                    txt.Color = (widget.value == i - 1) and theme.accent or theme.text
                    txt.Position = Vector2_new(dx + 8, oy + 3)
                    setVisible(txt, true)
                else
                    setVisible(box, false)
                    setVisible(txt, false)
                end
            end
        else
            setRoundedFillVisible(widget.dropdownBorder, false)
            setRoundedFillVisible(widget.dropdown, false)
            for i = 1, #widget.optionTexts do
                setVisible(widget.optionHovers[i], false)
                setVisible(widget.optionTexts[i], false)
            end
        end

    elseif widget.kind == "color_picker" then
        if clicked then
            widget.paletteIndex = widget.paletteIndex + 1
            if widget.paletteIndex > #COLOR_PALETTE then widget.paletteIndex = 1 end
            widget.value = COLOR_PALETTE[widget.paletteIndex]
            self._values[widget.id] = widget.value
            if widget.callback then widget.callback(widget.value, widget) end
        end
        widget.labelText.Text = widget.label
        widget.labelText.Size = 13
        widget.labelText.Color = theme.text
        widget.labelText.Position = Vector2_new(widget.x + 2, widget.y + 2)
        setVisible(widget.labelText, true)
        local cx = widget.x + widget.w - 8
        local cy = widget.y + math_floor(widget.h / 2)
        widget.dot.Position = Vector2_new(cx, cy)
        widget.dot.Radius = 5
        widget.dot.Color = isColor(widget.value) and widget.value or theme.white
        setVisible(widget.dot, true)

    elseif widget.kind == "toggle_color" then
        local toggleHit = inside(mx, my, widget.x, widget.y, widget.w - 20, widget.h)
        local swatchHit = inside(mx, my, widget.x + widget.w - 18, widget.y, 18, widget.h)
        if self._mouse.clicked and toggleHit then
            widget.value = not widget.value
            self._values[widget.id] = widget.value
            if widget.callback then widget.callback(widget.value, widget.color, widget) end
        end
        if self._mouse.clicked and swatchHit then
            widget.paletteIndex = widget.paletteIndex + 1
            if widget.paletteIndex > #COLOR_PALETTE then widget.paletteIndex = 1 end
            widget.color = COLOR_PALETTE[widget.paletteIndex]
            if widget.callback then widget.callback(widget.value, widget.color, widget) end
        end
        local cx = widget.x + 7
        local cy = widget.y + math_floor(widget.h / 2)
        widget.dotOuter.Position = Vector2_new(cx, cy); widget.dotOuter.Radius = 5
        widget.dotOuter.Color = widget.value and theme.accent or theme.muted
        widget.dotInner.Position = Vector2_new(cx, cy); widget.dotInner.Radius = 3
        widget.dotInner.Color = theme.accent
        setVisible(widget.dotOuter, true)
        setVisible(widget.dotInner, widget.value == true)
        widget.labelText.Text = widget.label
        widget.labelText.Size = 13
        widget.labelText.Color = widget.value and theme.text or theme.muted
        widget.labelText.Position = Vector2_new(widget.x + 18, widget.y + 2)
        setVisible(widget.labelText, true)
        local sx = widget.x + widget.w - 8
        widget.swatch.Position = Vector2_new(sx, cy)
        widget.swatch.Radius = 5
        widget.swatch.Color = isColor(widget.color) and widget.color or theme.white
        setVisible(widget.swatch, true)

    elseif widget.kind == "text" then
        widget.labelText.Text = widget.label
        widget.labelText.Size = 12
        widget.labelText.Color = theme.text
        widget.labelText.Position = Vector2_new(widget.x + 2, widget.y + 1)
        setVisible(widget.labelText, true)
    end
end

function Window:_handleDrag()
    local mx, my = self._mouse.x, self._mouse.y
    local headerHit = inside(mx, my, self.x, self.y, self.w, 36)
    if self.visible and self._mouse.clicked and headerHit then
        self._dragging = true
        self._dragOffsetX = mx - self.x
        self._dragOffsetY = my - self.y
    end
    if self._mouse.released then self._dragging = false end
    if self._dragging and self._mouse.down then
        self.x = math_floor(mx - self._dragOffsetX)
        self.y = math_floor(my - self._dragOffsetY)
    end
end

function Window:Step(_dt)
    if self._destroyed then return end
    self:_readMouse()
    self:_handleHotkeys()
    self:_handleDrag()
    self:_layoutShell()
    self:_layoutTabs()
    self:_layoutSections()
    self:_applyVisibility()
end

function Window:Pulse(seconds)
    local untilTime = os_clock() + (seconds or 2)
    while os_clock() < untilTime do
        self:Step(0)
        task.wait()
    end
end

-- Demo -----------------------------------------------------------------------

function VenusGUI:Demo(opts)
    opts = opts or {}

    local gui = VenusGUI.Create({
        Title = opts.Title or "Venus Library",
        Width = opts.Width or 380,
        Height = opts.Height or 560,
        ToggleKey = opts.ToggleKey or 0x70,
        ConfigFolder = opts.ConfigFolder,
    })

    local aimbot = gui:Tab("Aimbot")
    local visuals = gui:Tab("Visuals")
    local misc = gui:Tab("Misc")
    local settings = gui:Tab("Settings")

    local configStatus
    local configDropdown

    local function setStatus(text)
        text = asText(text)
        if configStatus then configStatus.label = text end
        print(text)
    end

    local function selectedConfigName()
        if configDropdown then
            local selected = asText(configDropdown:GetText())
            if selected and selected ~= "" then return selected end
        end
        return asText(gui:GetValue("config_name") or "default")
    end

    local function selectConfig(name)
        if not configDropdown then return end
        for i, item in ipairs(configDropdown:GetItems()) do
            if item == name then configDropdown:SetValue(i - 1); return end
        end
    end

    local function refreshStatus()
        local configs = gui:ListConfigs()
        if configDropdown then configDropdown:SetItems(configs) end
        if #configs == 0 then setStatus("No configs saved")
        else setStatus("Selected: " .. selectedConfigName()) end
    end

    -- Aimbot tab matches the screenshot
    local section = aimbot:Section("Section")
    section:Text("Label")
    section:Button("Button", function() setStatus("Button pressed") end)
    section:Toggle("aim_toggle", "Toggle", false)
    section:Box("aim_box", "Box", "")
    section:SliderInt("aim_slider", "Slider", 0, 100, 20)
    section:Combo("aim_dropdown", "", { "Option1", "Option2", "Option3" }, 0)
    section:Keybind("aim_keybind", "Keybind", 0x41, "toggle")
    section:ToggleKeybind("aim_toggle_keybind", "Toggle Keybind", false, 0x41, "toggle")
    section:ColorPicker("aim_color", "Color Picker", 255, 0, 255)
    section:ToggleColorPicker("aim_color_toggle", "Color Picker Toggle", false, 220, 70, 70)

    -- Visuals tab
    local esp = visuals:Section("ESP")
    esp:Toggle("esp_enabled", "Enabled", true)
    esp:Toggle("esp_boxes", "Boxes", true)
    esp:Toggle("esp_names", "Names", true)
    esp:SliderInt("esp_distance", "Max Distance", 100, 10000, 2500)
    esp:ColorPicker("esp_color", "ESP Color", 201, 148, 160)

    -- Misc tab
    local movement = misc:Section("Movement")
    movement:Toggle("bhop", "Bunny Hop", false)
    movement:SliderInt("walk", "Walk Speed", 16, 250, 16)
    movement:Keybind("move_key", "Movement Key", 0x47, "toggle")

    -- Settings tab: full config system, same workflow as MatchaGUI
    local createConfigs = settings:Section("Create Configs")
    createConfigs:InputText("config_name", "Name", "", nil, { skipConfig = true })
    createConfigs:Button("Create", function()
        local name = asText(gui:GetValue("config_name"))
        if name == "" then name = "default" end
        local ok, msg = gui:SaveConfig(name)
        if ok then
            setStatus("Saved: " .. msg); refreshStatus(); selectConfig(name)
        else
            setStatus("Save failed: " .. tostring(msg))
        end
    end)

    local configSettings = settings:Section("Config Settings")
    configDropdown = configSettings:Combo("selected_config", "Saved Configs", {}, 0, function(_, text)
        text = asText(text)
        if text ~= "" then
            gui:SetValue("config_name", text)
            setStatus("Selected: " .. text)
        end
    end, { skipConfig = true })
    configStatus = configSettings:Text("No configs saved")
    configSettings:Button("Load", function()
        local name = selectedConfigName()
        local ok, msg = gui:LoadConfig(name)
        setStatus(ok and ("Loaded: " .. name) or ("Load failed: " .. tostring(msg)))
    end)
    configSettings:Button("Update", function()
        local name = selectedConfigName()
        local ok, msg = gui:SaveConfig(name)
        if ok then
            setStatus("Updated: " .. msg); refreshStatus(); selectConfig(name)
        else
            setStatus("Update failed: " .. tostring(msg))
        end
    end)
    configSettings:Button("Delete", function()
        local name = selectedConfigName()
        local ok, msg = gui:DeleteConfig(name)
        if ok then setStatus("Deleted: " .. msg); refreshStatus()
        else setStatus("Delete failed: " .. tostring(msg)) end
    end)
    configSettings:Button("Refresh", refreshStatus)

    local other = settings:Section("Other")
    other:Toggle("show_keybinds", "Show Keybinds", false)
    other:MenuKeybind("menu_key", "Menu Key", 0x70)

    gui:SetTab(opts.Tab or "Aimbot")
    refreshStatus()

    if opts.Start ~= false then gui:Start() end
    if opts.Start ~= false and opts.Block ~= false then
        while not gui._destroyed do task.wait(60) end
    end

    return gui
end

function VenusGUI:ShowDemoMenu(opts) return self:Demo(opts) end

